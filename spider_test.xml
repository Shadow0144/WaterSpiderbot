    <! Right femur to coxa />
    <actuator>
        <position name="servo_right_i_femur_pitch" joint="right_i_coxa_femur_joint" kp="40" ctrlrange="0 90" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_right_ii_femur_pitch" joint="right_ii_coxa_femur_joint" kp="40" ctrlrange="0 90" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_right_iii_femur_pitch" joint="right_iii_coxa_femur_joint" kp="40" ctrlrange="-90 0" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_right_iv_femur_pitch" joint="right_iv_coxa_femur_joint" kp="40" ctrlrange="0 90" forcerange="-20 20"/>
    </actuator>

