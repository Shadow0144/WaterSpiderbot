<mujoco model="test_scene">

    <option gravity="0 0 -9.81" timestep="0.002" />

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
        <texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3" rgb2=".2 .3 .4" width="300" height="300" mark="edge" markrgb=".2 .3 .4"/>
        <material name="grid_floor" texture="grid" texrepeat="1 1" texuniform="true"/>
    </asset>

    <default>
        <default class="coxa">
            <joint type="hinge" axis="0 1 0" pos="0 0 0" limited="true" range="-45 45"/>
            <geom type="sphere" size="0.04" mass="1" contype="4" conaffinity="1"/>
        </default>
        <default class="femur">
            <joint type="hinge" axis="1 0 0" pos="0 0 0" limited="true" range="0 90"/>
            <geom type="capsule" fromto="0 0 0  0 0 -0.25" size="0.04" mass="1"/>
        </default>
        <default class="tibia">
            <joint type="hinge" axis="1 0 0" pos="0 0 0" limited="true" range="0 45"/>
            <geom type="capsule" fromto="0 0 0  0 0 -0.25" size="0.02" mass="1"/>
        </default>
        <default class="claw">
            <geom type="capsule" fromto="0 0 0  0 0 -0.025" size="0.02" rgba="0.5 0.5 0.5 1" friction="5.0 0.01 0.001"/>
        </default>
    </default>

    <worldbody>
        <light pos="0 0 4" dir="0 0 -1" castshadow="true"/>

        <geom name="floor" type="plane" size="0 0 .25" material="grid_floor" contype="1" conaffinity="7"/>

        <body name="cephalothorax" pos="0 0 0.5">
            <freejoint name="cephalothorax_joint"/>
            <geom type="ellipsoid" size="0.25 0.25 0.125" rgba="0 0 0 1" mass="0.5" friction="1 0.01 0.0001" contype="2" conaffinity="1"/>
            
            <body name="abdomen" pos="0 -0.5 0">
                <geom type="ellipsoid" size="0.3 0.3 0.175"  rgba="0.2 0.2 0.2 1" mass="0.05" friction="1 0.01 0.0001"/>
            </body>
            
            <! Eyes>
            <camera name="left_eye" pos="-0.045 0.25 0" euler="90 0 0"/>
            <camera name="right_eye" pos="0.045 0.25 0" euler="90 0 0"/>

            <! cephalothorax connects to coxa [then trochanter] then femur [then patella] then tibia [then metatarsus] [then tarsus] then claws />
            <! legs are built dynamically in the python code />

        </body>
    </worldbody>

    <! Left coxa to cephalothorax />
    <actuator>
        <position name="servo_left_i_coxa_pitch" joint="left_i_cephalothorax_coxa_joint" kp="40" ctrlrange="-45 45" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_left_ii_coxa_pitch" joint="left_ii_cephalothorax_coxa_joint" kp="40" ctrlrange="-45 45" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_left_iii_coxa_pitch" joint="left_iii_cephalothorax_coxa_joint" kp="40" ctrlrange="-45 45" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_left_iv_coxa_pitch" joint="left_iv_cephalothorax_coxa_joint" kp="40" ctrlrange="-45 45" forcerange="-20 20"/>
    </actuator>

    <! Left femur to coxa />
    <actuator>
        <position name="servo_left_i_femur_pitch" joint="left_i_coxa_femur_joint" kp="40" ctrlrange="0 90" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_left_ii_femur_pitch" joint="left_ii_coxa_femur_joint" kp="40" ctrlrange="0 90" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_left_iii_femur_pitch" joint="left_iii_coxa_femur_joint" kp="40" ctrlrange="0 90" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_left_iv_femur_pitch" joint="left_iv_coxa_femur_joint" kp="40" ctrlrange="0 90" forcerange="-20 20"/>
    </actuator>

    <! Left tibia to femur />
    <actuator>
        <position name="servo_left_i_tibia_pitch" joint="left_i_femur_tibia_joint" kp="40" ctrlrange="0 90" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_left_ii_tibia_pitch" joint="left_ii_femur_tibia_joint" kp="40" ctrlrange="0 90" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_left_iii_tibia_pitch" joint="left_iii_femur_tibia_joint" kp="40" ctrlrange="0 90" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_left_iv_tibia_pitch" joint="left_iv_femur_tibia_joint" kp="40" ctrlrange="0 90" forcerange="-20 20"/>
    </actuator>

    <! Right coxa to body />
    <actuator>
        <position name="servo_right_i_coxa_pitch" joint="right_i_cephalothorax_coxa_joint" kp="40" ctrlrange="-45 45" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_right_ii_coxa_pitch" joint="right_ii_cephalothorax_coxa_joint" kp="40" ctrlrange="-45 45" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_right_iii_coxa_pitch" joint="right_iii_cephalothorax_coxa_joint" kp="40" ctrlrange="-45 45" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_right_iv_coxa_pitch" joint="right_iv_cephalothorax_coxa_joint" kp="40" ctrlrange="-45 45" forcerange="-20 20"/>
    </actuator>

    <! Right femur to coxa />
    <actuator>
        <position name="servo_right_i_femur_pitch" joint="right_i_coxa_femur_joint" kp="40" ctrlrange="0 90" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_right_ii_femur_pitch" joint="right_ii_coxa_femur_joint" kp="40" ctrlrange="0 90" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_right_iii_femur_pitch" joint="right_iii_coxa_femur_joint" kp="40" ctrlrange="-90 0" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_right_iv_femur_pitch" joint="right_iv_coxa_femur_joint" kp="40" ctrlrange="0 90" forcerange="-20 20"/>
    </actuator>

    <! Right tibia to femur />
    <actuator>
        <position name="servo_right_i_tibia_pitch" joint="right_i_femur_tibia_joint" kp="40" ctrlrange="-90 0" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_right_ii_tibia_pitch" joint="right_ii_femur_tibia_joint" kp="40" ctrlrange="-90 0" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_right_iii_tibia_pitch" joint="right_iii_femur_tibia_joint" kp="40" ctrlrange="0 90" forcerange="-20 20"/>
    </actuator>
    <actuator>
        <position name="servo_right_iv_tibia_pitch" joint="right_iv_femur_tibia_joint" kp="40" ctrlrange="0 90" forcerange="-20 20"/>
    </actuator>

</mujoco>